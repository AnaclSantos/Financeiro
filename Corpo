<script>
function showBlock(id, btn) {
  document.querySelectorAll('.block').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('block-' + id).classList.add('active');
  btn.classList.add('active');
}
 
function makeBars(containerId, axId, groups, maxVal) {
  const c = document.getElementById(containerId);
  const ax = document.getElementById(axId);
  if (!c) return;
  c.innerHTML = '';
  if (ax) ax.innerHTML = '';
  groups.forEach(g => {
    const grp = document.createElement('div');
    grp.className = 'bar-group';
    g.values.forEach((v, vi) => {
      const b = document.createElement('div');
      b.className = 'bar';
      const pct = Math.round((v / maxVal) * 100);
      b.style.height = pct + '%';
      b.style.background = g.colors[vi];
      b.title = g.labels[vi] + ': ' + v;
      grp.appendChild(b);
    });
    c.appendChild(grp);
    if (ax) {
      const l = document.createElement('div');
      l.className = 'bar-axis-lbl';
      l.textContent = g.name;
      ax.appendChild(l);
    }
  });
}
 
const meses = ['Jan','Fev','Mar','Abr','Mai','Jun'];
const receitas = [38,42,35,45,41,48];
const despesas = [28,30,27,29,30,31];
const economias = [10,12,8,16,11,17];
 
// Receita vs Despesa vs Economia: Verde Principal, Vermelho Auxiliar, Azul Auxiliar
makeBars('bar-geral','bar-geral-ax',
  meses.map((m,i) => ({ name: m, labels:['Receita','Despesa','Economia'], values:[receitas[i],despesas[i]*0.7,economias[i]*0.7], colors:['#365833','#A32E16','#427882'] })), 55);
 
// Receita Recorrente vs Nova: Azul Auxiliar, Âmbar Auxiliar
makeBars('bar-recorrente','bar-recorrente-ax',
  meses.map((m,i) => ({ name: m, labels:['Recorrente','Nova'], values:[Math.round(receitas[i]*0.37),Math.round(receitas[i]*0.63)], colors:['#427882','#967D69'] })), 50);
 
// Balanço Mensal: Verde Principal ou Vermelho Auxiliar
makeBars('bar-balanco','bar-balanco-ax',
  meses.map((m,i) => { const v = receitas[i]-despesas[i]; return { name: m, labels:['Balanço'], values:[Math.round(v*2.5)], colors:[v>0?'#365833':'#A32E16'] }; }), 60);
 
// Burn Rate: Vermelho Auxiliar
const burnVals = [29,31,28,30,29,31];
makeBars('bar-burn','bar-burn-ax',
  meses.map((m,i) => ({ name: m, labels:['Burn Rate'], values:[Math.round(burnVals[i]*1.8)], colors:['#A32E16'] })), 65);
 
// Orçado vs Realizado: Azul Auxiliar, Vermelho Auxiliar
const catLabels = ['RH','Mktg','Infra','Coml','Outro'];
const orcado = [10,5,5.5,4,6];
const realiz = [9.8,6.2,5.1,4.4,5.5];
makeBars('bar-orca','bar-orca-ax',
  catLabels.map((l,i) => ({ name: l, labels:['Orçado','Realizado'], values:[Math.round(orcado[i]*5.5),Math.round(realiz[i]*5.5)], colors:['#427882','#A32E16'] })), 70);
 
// Donut: Despesas (Vermelho Auxiliar), Economia (Azul Auxiliar)
const donutCtx = document.getElementById('donut-renda');
if (donutCtx) {
  new Chart(donutCtx, {
    type: 'doughnut',
    data: { datasets: [{ data: [65,35], backgroundColor: ['#A32E16','#427882'], borderWidth: 0 }] },
    options: { responsive: false, cutout: '68%', plugins: { legend: { display: false }, tooltip: { enabled: false } } }
  });
}
</script>
